# RELEASE: nodusrf/nodus-edge .env.example
# NodusEdge — Edge Node Configuration
# Copy this file to .env and edit the values below.

# === Required: Frequencies ===
# Frequencies to monitor in Hz (comma-separated).
# Example: two national simplex + one local repeater
NODUS_EDGE_FM_CORE_FREQUENCIES=146520000,146940000,147000000

# === NodusNet Server ===
# Server endpoint (auth is handled automatically via REM check-in)
NODUSNET_SERVER=https://api.nodusrf.com

# === Whisper (default: bundled CPU container) ===
# The compose file runs a local CPU Whisper container.
# Override to point at a remote GPU Whisper server:
NODUS_EDGE_WHISPER_API_URL=http://whisper:8000
# NODUS_EDGE_WHISPER_API_URL=http://your-gpu-server:8000
# On Raspberry Pi, the setup wizard auto-configures NodusNet cloud transcription:
# NODUS_EDGE_WHISPER_API_URL=https://api.nodusrf.com/v1/edge/whisper

# === Whisper Model (CPU container) ===
# base = fast, good enough for clear FM audio (~1x realtime on modern CPU)
# small = better accuracy, ~3x slower
# medium = best accuracy, ~8x slower — not recommended for CPU
WHISPER_MODEL=base

# === Node Identity ===
# Unique name for this edge node (appears in Synapse/Cortex)
NODUS_EDGE_NODE_ID=edge-your-callsign
# Metro area slug (e.g., "phoenix", "omaha") — used for grouping
NODUS_EDGE_METRO=

# === Scanner Backend ===
# airband = RTLSDR-Airband simultaneous multi-channel (recommended)
# rtl_fm  = legacy sequential scanner (fallback if airband binary missing)
NODUS_EDGE_FM_SCANNER_BACKEND=airband
NODUS_EDGE_FM_GAIN=40
NODUS_EDGE_FM_SQUELCH_THRESHOLD=15

# === Critical FM Settings ===
# DO NOT change these unless you know what you're doing.
NODUS_EDGE_WHISPER_VAD_FILTER=false
NODUS_EDGE_FM_HALLUCINATION_FILTER_ENABLED=true
NODUS_EDGE_FM_MORSE_DETECTION_ENABLED=true
NODUS_EDGE_FM_EXTRACT_CALLSIGNS=true

# === Edge Dashboard ===
# Local web UI at localhost:8073 — works fully offline
NODUS_EDGE_DASHBOARD_ENABLED=true
NODUS_EDGE_DASHBOARD_PORT=8073
